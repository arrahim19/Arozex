{
  "name": "arozex-technologies",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-next-artifacts.ps1 all",
    "clean:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-next-artifacts.ps1 dev",
    "clean:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-next-artifacts.ps1 build",
    "check:no-dev-server": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-no-dev-server.ps1",
    "dev": "npm run clean:dev && next dev -p 3000",
    "build": "npm run clean:build && npm run check:no-dev-server && next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.3.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.8.3"
  }
}
