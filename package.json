{
  "name": "arozex-technologies",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "node scripts/clean-next-artifacts.mjs all",
    "clean:dev": "node scripts/clean-next-artifacts.mjs dev",
    "clean:build": "node scripts/clean-next-artifacts.mjs build",
    "check:no-dev-server": "node scripts/check-no-dev-server.mjs",
    "dev": "npm run check:no-dev-server && npm run clean:dev && next dev -p 3000",
    "build": "npm run clean:build && npm run check:no-dev-server && next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.3.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.8.3"
  }
}
